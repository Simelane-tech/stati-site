# Copy this file to .env and fill in real values. NEVER commit .env to git.

# Gmail account that sends the emails (must match the Google account that generated the App Password)
SMTP_USER=sibeve.sales@gmail.com

# Gmail App Password (16 chars, no spaces). Create at:
# https://myaccount.google.com/apppasswords  (requires 2-Step Verification enabled)
SMTP_PASS=your_16_char_app_password_here

# Where notification emails are delivered
MAIL_TO=sibeve.sales@gmail.com

# Display "From" header
MAIL_FROM=Sibeve Group <sibeve.sales@gmail.com>

# Server port (optional, default 3000)
PORT=3000

# Set to "true" only if your network (corporate AV/proxy) intercepts TLS to smtp.gmail.com
# and you get "unable to verify the first certificate". Disables cert verification on SMTP.
SMTP_INSECURE_TLS=false
